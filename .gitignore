*.pyo
*.pyd
.Python
env/
venv/
.venv/

# Node.js (if any Node scripts in project)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*~
